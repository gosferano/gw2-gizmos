<Project Sdk="Microsoft.NET.Sdk">

  <!-- Hardcoded reference data the GW2 API doesn't expose: world-boss / meta-event schedules (no timer
       endpoint exists), Mystic Forge recipes, and vendor buy-prices. Pure data + models, no dependencies. -->

