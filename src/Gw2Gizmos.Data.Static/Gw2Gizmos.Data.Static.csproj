       price vendor-bought items and Mystic-Forge intermediates that the API doesn't cover. -->
  <ItemGroup>
    <EmbeddedResource Include="Crafting\Data\*.json" />
    <EmbeddedResource Include="Crafting\Data\*.json.gz" />
  </ItemGroup>

</Project>
