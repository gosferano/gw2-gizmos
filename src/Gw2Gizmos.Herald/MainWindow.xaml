<Window x:Class="Gw2Gizmos.Herald.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gw2Gizmos.Herald"
        mc:Ignorable="d"
        Title="Gw2Gizmos Herald" Height="300" Width="480"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Gw2Gizmos Herald" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Notifies you when your trading-post deliveries change."
                       Foreground="Gray" Margin="0,2,0,20" />

            <TextBlock Text="GW2 API Key" FontWeight="SemiBold" />
            <TextBlock Text="Needs the 'account' and 'tradingpost' scopes. Create one at account.arena.net."
                       Foreground="Gray" FontSize="11" Margin="0,0,0,6" TextWrapping="Wrap" />
            <TextBox x:Name="ApiKeyBox" Height="28" VerticalContentAlignment="Center"
                     FontFamily="Consolas" />

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button x:Name="SaveButton" Content="Save key" Padding="16,5" Click="SaveButton_Click" />
                <Button x:Name="ClearButton" Content="Clear" Padding="16,5" Margin="8,0,0,0" Click="ClearButton_Click" />
                <TextBlock x:Name="StatusText" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="Gray" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
