<Application x:Class="Gw2Gizmos.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Gw2Gizmos.Desktop"
             xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
             xmlns:conv="clr-namespace:Gw2Gizmos.Desktop.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared by the Account sub-pages (bank / shared inventory / material storage grids). -->
            <conv:BoolToVisibilityConverter x:Key="Bool" />
            <conv:BoolToVisibilityConverter x:Key="InverseBool" Invert="True" />

            <!-- A bank/shared-inventory slot, or a placeholder when empty. The cell fills its 10-column
                 UniformGrid column and is square (Height tracks width) → exactly 10 per row with equal
                 spacing on both axes. The icon has a uniform margin so there's always an equal gap. -->
            <DataTemplate x:Key="SlotTemplate">
                <Grid Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}" ToolTip="{Binding Name}">
                    <!-- Empty slots have no name, so suppress the (otherwise blank) tooltip on hover. -->
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="ToolTipService.IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <!-- Placeholder tile, always drawn: an empty slot shows it alone, and a filled slot whose
                         item hasn't synced yet (icon not downloaded) still reads as occupied — with its known
                         count — instead of a blank gap. The icon paints over the tile once it's available. -->
                    <Border Margin="5" CornerRadius="6" BorderThickness="1"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}" />
                    <c:ItemImage ItemId="{Binding ItemId}" CornerRadius="6" Stretch="Uniform" Margin="5"
                                 Visibility="{Binding IsEmpty, Converter={StaticResource InverseBool}}" />
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                            Background="#CC000000" CornerRadius="4" Padding="4,0"
                            Visibility="{Binding HasCount, Converter={StaticResource Bool}}">
                        <TextBlock Text="{Binding CountDisplay}" FontSize="11" Foreground="White" />
                    </Border>
                </Grid>
            </DataTemplate>

            <!-- A material-storage cell: like a slot, but the count is always shown (0 included). -->
            <DataTemplate x:Key="MaterialCellTemplate">
                <Grid Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}" ToolTip="{Binding Name}">
                    <!-- Always-drawn placeholder tile, so an un-synced material still shows its known count
                         over a slot instead of a blank cell; the icon paints over it once downloaded. -->
                    <Border Margin="5" CornerRadius="6" BorderThickness="1"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}" />
                    <c:ItemImage ItemId="{Binding ItemId}" CornerRadius="6" Stretch="Uniform" Margin="5"
                                 Desaturate="{Binding IsZero}" />
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                            Background="#CC000000" CornerRadius="4" Padding="4,0">
                        <TextBlock Text="{Binding CountDisplay}" FontSize="11" Foreground="White" />
                    </Border>
                </Grid>
            </DataTemplate>

            <!-- Subtle hover highlight, identical to the Account → Wallet rows: the default Transparent comes
                 from a style setter (not a local value) so the IsMouseOver trigger can override it. -->
            <Style x:Key="SessionLootRowStyle" TargetType="Border">
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Background" Value="Transparent" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- A session "hoarded" currency row — same size/layout + hover highlight as the Wallet entries, with a
                 hover tooltip. DeltaDisplay is the signed gain/loss. -->
            <DataTemplate x:Key="SessionCurrencyRowTemplate">
                <Border Style="{StaticResource SessionLootRowStyle}" ToolTip="{Binding Name}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" FontWeight="Medium" VerticalAlignment="Center"
                                   Text="{Binding DeltaDisplay}" />
                        <c:CurrencyImage IconUrl="{Binding IconUrl}" Width="28" Height="28" Margin="0,0,10,0"
                                         VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </DockPanel>
                </Border>
            </DataTemplate>

            <!-- A session "hoarded" item row — matches the currency row (wallet-sized, hover highlight + tooltip). -->
            <DataTemplate x:Key="SessionItemRowTemplate">
                <Border Style="{StaticResource SessionLootRowStyle}" ToolTip="{Binding Name}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" FontWeight="Medium" VerticalAlignment="Center"
                                   Text="{Binding DeltaDisplay}" />
                        <c:ItemImage ItemId="{Binding ItemId}" Width="28" Height="28" Margin="0,0,10,0"
                                     CornerRadius="4" Stretch="Uniform" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </DockPanel>
                </Border>
            </DataTemplate>

            <!-- Win11-Settings-style page chrome: a pinned title/breadcrumb over a width-capped, centered
                 body. Scrollable bodies scroll under the header; non-scrollable ones (grids) fill the
                 height and scroll internally. -->
            <Style TargetType="{x:Type c:PageShell}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type c:PageShell}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Pinned breadcrumb header (every page; multi-level + clickable for sub-pages) -->
                                <c:CenteredContent Grid.Row="0" MaxContentWidth="{TemplateBinding MaxContentWidth}"
                                                   Margin="36,18,36,8">
                                    <ui:BreadcrumbBar x:Name="PART_Breadcrumb"
                                                      ItemsSource="{TemplateBinding ResolvedBreadcrumbs}">
                                        <ui:BreadcrumbBar.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            </DataTemplate>
                                        </ui:BreadcrumbBar.ItemTemplate>
                                    </ui:BreadcrumbBar>
                                </c:CenteredContent>

                                <!-- Body: scrolls (Auto) for content pages, fills (Disabled) for grids -->
                                <ScrollViewer x:Name="BodyScroll" Grid.Row="1"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              Focusable="False">
                                    <c:CenteredContent MaxContentWidth="{TemplateBinding MaxContentWidth}"
                                                       Margin="36,4,36,24">
                                        <ContentPresenter />
                                    </c:CenteredContent>
                                </ScrollViewer>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="Scrollable" Value="False">
                                    <Setter TargetName="BodyScroll" Property="VerticalScrollBarVisibility"
                                            Value="Disabled" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
