<Application x:Class="Gw2Gizmos.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Gw2Gizmos.Desktop"
             xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Win11-Settings-style page chrome: a pinned title/breadcrumb over a width-capped, centered
                 body. Scrollable bodies scroll under the header; non-scrollable ones (grids) fill the
                 height and scroll internally. -->
            <Style TargetType="{x:Type c:PageShell}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type c:PageShell}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Pinned breadcrumb / title -->
                                <c:CenteredContent Grid.Row="0" MaxContentWidth="{TemplateBinding MaxContentWidth}"
                                                   Margin="36,18,36,8">
                                    <TextBlock Text="{TemplateBinding Title}" FontSize="28" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </c:CenteredContent>

                                <!-- Body: scrolls (Auto) for content pages, fills (Disabled) for grids -->
                                <ScrollViewer x:Name="BodyScroll" Grid.Row="1"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              Focusable="False">
                                    <c:CenteredContent MaxContentWidth="{TemplateBinding MaxContentWidth}"
                                                       Margin="36,4,36,24">
                                        <ContentPresenter />
                                    </c:CenteredContent>
                                </ScrollViewer>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="Scrollable" Value="False">
                                    <Setter TargetName="BodyScroll" Property="VerticalScrollBarVisibility"
                                            Value="Disabled" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
