<Page x:Class="Gw2Gizmos.Desktop.AdvancedSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Advanced">
    <c:PageShell Breadcrumbs="{Binding Breadcrumbs}">
        <StackPanel>
            <!-- Yellow caution box: changing these isn't recommended. -->
            <Border CornerRadius="{DynamicResource ControlCornerRadius}" Padding="14,12" Margin="0,0,0,16"
                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                    BorderBrush="{DynamicResource SystemFillColorCautionBrush}" BorderThickness="1">
                <DockPanel>
                    <ui:SymbolIcon DockPanel.Dock="Left" Symbol="Warning24" FontSize="20" Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                               Text="Changing these sync intervals from their defaults isn't recommended. Shorter intervals mean more GW2 API calls." />
                </DockPanel>
            </Border>

            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="How often the worker refreshes each kind of data." />

            <ItemsControl ItemsSource="{Binding Syncs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="16,12">
                            <DockPanel>
                                <ComboBox DockPanel.Dock="Right" MinWidth="130" VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          ItemsSource="{Binding Options}"
                                          SelectedItem="{Binding Selected, Mode=TwoWay}" />
                                <TextBlock Text="{Binding Display}" FontWeight="Medium" FontSize="14"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </c:PageShell>
</Page>
