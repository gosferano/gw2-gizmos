<Page x:Class="Gw2Gizmos.Desktop.SessionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Sessions">
    <c:PageShell Title="Sessions">
        <StackPanel>
            <!-- No account picked yet -->
            <ui:Card Margin="0,4,0,0" Padding="20" Visibility="{Binding HasAccount, Converter={StaticResource InverseBool}}">
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="No account selected. Add an API key and pick an account on the API keys page." />
            </ui:Card>

            <StackPanel Visibility="{Binding HasAccount, Converter={StaticResource Bool}}">
                <!-- Account selected but nothing recorded yet -->
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Visibility="{Binding HasSessions, Converter={StaticResource InverseBool}}" />

                <!-- One card per play session → its character timeline. -->
                <ItemsControl ItemsSource="{Binding Sessions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:CardAction Margin="0,0,0,8"
                                           Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="History24" FontSize="24" Margin="0,0,16,0" VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="14" />
                                        <TextBlock Text="{Binding Subtitle}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardAction>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </c:PageShell>
</Page>
