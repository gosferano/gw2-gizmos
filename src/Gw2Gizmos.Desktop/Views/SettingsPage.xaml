<Page x:Class="Gw2Gizmos.Desktop.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Settings">
    <c:PageShell Title="Settings">
        <StackPanel>
            <TextBlock Margin="0,0,0,14" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Turn the data the worker syncs on or off. A feature that's on but whose API key lacks the permission it needs is flagged here and in red on the API keys page." />

            <ItemsControl ItemsSource="{Binding Features}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="16,12">
                            <DockPanel>
                                <ui:ToggleSwitch DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                                                 IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Display}" FontWeight="Medium" FontSize="14"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding Permissions}" FontSize="12" Margin="0,3,0,0"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{Binding Warning}" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"
                                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                               Visibility="{Binding HasWarning, Converter={StaticResource Bool}}" />
                                </StackPanel>
                            </DockPanel>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Advanced: per-sync intervals, behind a chevron card (with a "not recommended" warning inside). -->
            <ui:CardAction Click="OnOpenAdvanced" Margin="0,14,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Options24" FontSize="24" Margin="0,0,16,0" VerticalAlignment="Center" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Advanced" FontWeight="Medium" FontSize="14" />
                        <TextBlock Text="Sync intervals" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </ui:CardAction>
        </StackPanel>
    </c:PageShell>
</Page>
