<Page x:Class="Gw2Gizmos.Desktop.MarketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      xmlns:conv="clr-namespace:Gw2Gizmos.Desktop.Converters"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:model="clr-namespace:Gw2Gizmos.RecipeFinder.Model;assembly=Gw2Gizmos.RecipeFinder"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Market">
    <c:PageShell Title="Market" Scrollable="False">
        <c:PageShell.Resources>
            <conv:CoinConverter x:Key="Coin" />
            <conv:BoolToVisibilityConverter x:Key="Bool" />
            <conv:BoolToVisibilityConverter x:Key="InverseBool" Invert="True" />
        </c:PageShell.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Opacity="0.7">
                    <Run Text="Every tradeable item, with craft cost and profit where craftable. Updated" />
                    <Run Text="{Binding ComputedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}', Mode=OneWay}" />
                </TextBlock>
                <ui:TextBox Grid.Column="1" Width="220" PlaceholderText="search items"
                            Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <ui:Card Grid.Row="1" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <DataGrid ItemsSource="{Binding View}"
                      SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserResizeRows="False" CanUserSortColumns="True" SelectionMode="Single"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent"
                      FontSize="13"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Item" Width="*" SortMemberPath="Name">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <c:ItemImage ItemId="{Binding ItemId}" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Buy" Width="100"
                                        Binding="{Binding Buy, Converter={StaticResource Coin}}" />
                    <DataGridTextColumn Header="Demand" Width="75"
                                        Binding="{Binding Demand, StringFormat='{}{0:N0}'}" />
                    <DataGridTextColumn Header="Sell" Width="100"
                                        Binding="{Binding Sell, Converter={StaticResource Coin}}" />
                    <DataGridTextColumn Header="Supply" Width="75"
                                        Binding="{Binding Supply, StringFormat='{}{0:N0}'}" />
                    <DataGridTextColumn Header="Craft cost" Width="100"
                                        Binding="{Binding CraftingCost, Converter={StaticResource Coin}}" />
                    <DataGridTextColumn Header="Profit" Width="100"
                                        Binding="{Binding Profit, Converter={StaticResource Coin}}" />
                    <DataGridTextColumn Header="Margin" Width="70"
                                        Binding="{Binding MarginPercent, StringFormat='{}{0:F0}%'}" />
                </DataGrid.Columns>
            </DataGrid>
            </ui:Card>

            <GridSplitter Grid.Row="2" Height="8" HorizontalAlignment="Stretch"
                          VerticalAlignment="Center" Background="Transparent" />

            <ui:Card Grid.Row="3" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Header="History">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="70" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.RowSpan="2" Text="Select an item to see its price history."
                                       Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding History.HasData, Converter={StaticResource InverseBool}}" />

                            <!-- Detail chart: buy/sell lines + volume columns; X range driven by the navigator. -->
                            <lvc:CartesianChart Grid.Row="0" Series="{Binding History.Series}"
                                                XAxes="{Binding History.TimeAxes}" YAxes="{Binding History.ValueAxes}"
                                                TooltipPosition="Top" ZoomMode="None"
                                                FindingStrategy="CompareOnlyXTakeClosest"
                                                Visibility="{Binding History.HasData, Converter={StaticResource Bool}}" />

                            <!-- Navigator: full history with a draggable window that sets the detail range. -->
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding History.NavigatorSeries}"
                                                XAxes="{Binding History.NavigatorTimeAxes}" YAxes="{Binding History.NavigatorValueAxes}"
                                                Sections="{Binding History.Sections}" TooltipPosition="Hidden"
                                                PointerPressedCommand="{Binding History.PointerDownCommand}"
                                                PointerMoveCommand="{Binding History.PointerMoveCommand}"
                                                PointerReleasedCommand="{Binding History.PointerUpCommand}"
                                                Visibility="{Binding History.HasData, Converter={StaticResource Bool}}" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Craft tree">
                        <TreeView ItemsSource="{Binding SelectedTree}" Background="Transparent" BorderThickness="0"
                                  Margin="0,8,0,0">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                    <Setter Property="IsExpanded" Value="True" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type model:RecipeNode}"
                                                          ItemsSource="{Binding Ingredients}">
                                    <StackPanel Orientation="Horizontal">
                                        <c:ItemImage ItemId="{Binding ItemId}" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding Count}" FontWeight="Medium" />
                                        <TextBlock Text="x " FontWeight="Medium" />
                                        <TextBlock Text="{Binding ItemName}" FontWeight="Medium" />
                                        <TextBlock Text="  ·  craft " Opacity="0.6" />
                                        <TextBlock Text="{Binding CraftingCost, Converter={StaticResource Coin}}" Opacity="0.6" />
                                        <TextBlock Text="  buy " Opacity="0.6" />
                                        <TextBlock Text="{Binding BuyPrice, Converter={StaticResource Coin}}" Opacity="0.6" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </TabItem>
                </TabControl>
            </ui:Card>
        </Grid>
    </c:PageShell>
</Page>
