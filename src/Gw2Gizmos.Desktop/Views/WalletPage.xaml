<Page x:Class="Gw2Gizmos.Desktop.WalletPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Gw2Gizmos.Desktop"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Wallet">
    <c:PageShell Breadcrumbs="{Binding Breadcrumbs}">

        <ItemsControl ItemsSource="{Binding Wallet}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Subtle hover highlight so it's clear which amount belongs to which currency. The
                         default Transparent comes from the style setter (not a local value), so the hover
                         trigger can override it — a local Background would win over the trigger. -->
                    <Border Padding="8,5" CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" FontWeight="Medium" VerticalAlignment="Center"
                                       Text="{Binding Value, StringFormat='{}{0:N0}'}" />
                            <c:CurrencyImage IconUrl="{Binding IconUrl}" Width="28" Height="28" Margin="0,0,10,0"
                                             VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </c:PageShell>
</Page>
