<Page x:Class="Gw2Gizmos.Desktop.OnboardingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Welcome">
    <c:PageShell Title="Welcome to Gw2Gizmos" MaxContentWidth="620">
        <StackPanel>
            <TextBlock TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,16"
                       Text="Gw2Gizmos tracks your Guild Wars 2 account — wallet, materials, bank, characters, prices, and play sessions — in a local database on your PC. To read your account, it needs a GW2 API key. Let's set one up." />

            <!-- Step 1: create the key -->
            <ui:Card Margin="0,0,0,10" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="1 · Create an API key" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" Margin="0,4,0,10"
                               Text="Open the Guild Wars 2 account site and create a new API key (you'll need to log in)." />
                    <ui:Button Content="Open account.arena.net" Command="{Binding OpenApiKeyPageCommand}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Open24" />
                        </ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

            <!-- Step 2: the permissions to tick -->
            <ui:Card Margin="0,0,0,10" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="2 · Enable these permissions" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" Margin="0,4,0,10"
                               Text="When creating the key, tick these boxes. They're everything Gw2Gizmos uses — and nothing more." />
                    <ItemsControl ItemsSource="{Binding RecommendedPermissions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,7,6" Padding="9,4" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Margin="0,0,5,0"
                                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                        <TextBlock Text="{Binding}" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>

            <!-- Step 3: paste + verify -->
            <ui:Card Margin="0,0,0,10" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="3 · Paste your key" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" Margin="0,4,0,10"
                               Text="Copy the key from the site and paste it here to connect your account." />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Text="{Binding ApiKeyInput, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="paste key here" FontFamily="Consolas" />
                        <ui:Button Grid.Column="1" Content="Connect" Command="{Binding AddCommand}"
                                   Appearance="Primary" Margin="8,0,0,0" />
                    </Grid>
                    <TextBlock Text="{Binding Status}" Opacity="0.85" Margin="0,8,0,0" TextWrapping="Wrap" />

                    <!-- Confirmation, shown once a key validates -->
                    <Border Margin="0,12,0,0" Padding="12,10" CornerRadius="6"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            Visibility="{Binding Verified, Converter={StaticResource Bool}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="18"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                                    <Run Text="Connected" />
                                    <Run Text="{Binding VerifiedAccount, Mode=OneWay}" FontWeight="SemiBold" />
                                </TextBlock>
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" Opacity="0.75" Margin="0,6,0,10"
                                       Text="Your data will start syncing in the background. You can add more accounts or change what's tracked any time in API keys and Settings." />
                            <ui:Button Content="Continue to dashboard" Command="{Binding ContinueCommand}"
                                       Appearance="Primary" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ui:Card>

            <!-- Escape hatch: explore first, set up later -->
            <ui:Button Content="Skip for now" Command="{Binding SkipCommand}" Appearance="Transparent"
                       HorizontalAlignment="Left" Margin="0,4,0,0" />
        </StackPanel>
    </c:PageShell>
</Page>
