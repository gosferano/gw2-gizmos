<Page x:Class="Gw2Gizmos.Desktop.StoredDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Stored data">
    <c:PageShell Breadcrumbs="{Binding Breadcrumbs}">
        <StackPanel>
            <TextBlock Margin="0,0,0,12" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Delete locally-stored data. This clears the stored rows; current data re-syncs on the next update (play sessions and price history don't come back)." />

            <!-- Global (non-account) data. -->
            <ui:Card Padding="12,8" Margin="0,0,0,8">
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="Delete" Appearance="Danger" VerticalAlignment="Center"
                               Height="{StaticResource FormControlHeight}" Command="{Binding PriceHistory.Delete}" />
                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="80"
                               TextAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding PriceHistory.CountDisplay}" />
                    <TextBlock Text="{Binding PriceHistory.Display}" VerticalAlignment="Center" />
                </DockPanel>
            </ui:Card>

            <!-- One expander per account. -->
            <ItemsControl ItemsSource="{Binding Accounts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardExpander Margin="0,0,0,8" Header="{Binding AccountName}">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding Types}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,6">
                                                <ui:Button DockPanel.Dock="Right" Content="Delete" Appearance="Danger"
                                                           VerticalAlignment="Center" Height="{StaticResource FormControlHeight}"
                                                           Command="{Binding Delete}" />
                                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,12,0"
                                                           MinWidth="80" TextAlignment="Right"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Text="{Binding CountDisplay}" />
                                                <TextBlock Text="{Binding Display}" VerticalAlignment="Center" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ui:Button Content="Delete all data for this account" Appearance="Danger"
                                           Margin="0,4,0,0" HorizontalAlignment="Left"
                                           Height="{StaticResource FormControlHeight}" Command="{Binding DeleteAll}" />
                            </StackPanel>
                        </ui:CardExpander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </c:PageShell>
</Page>
