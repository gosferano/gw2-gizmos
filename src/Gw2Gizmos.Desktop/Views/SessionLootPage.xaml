<Page x:Class="Gw2Gizmos.Desktop.SessionLootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Session loot">
    <c:PageShell Breadcrumbs="{Binding Breadcrumbs}">
        <StackPanel>
            <!-- Nothing changed during this segment -->
            <ui:Card Margin="0,4,0,0" Padding="20" Visibility="{Binding IsEmpty, Converter={StaticResource Bool}}">
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="No currency or item changes were recorded while this character was active. Account-wide gains are best-effort and depend on the Wallet/Materials/Bank/Characters features being enabled." />
            </ui:Card>

            <!-- Currencies -->
            <StackPanel Visibility="{Binding HasCurrencies, Converter={StaticResource Bool}}" Margin="0,4,0,0">
                <TextBlock Text="Currencies" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding Currencies}" ItemTemplate="{StaticResource SessionCurrencyRowTemplate}" />
            </StackPanel>

            <!-- Items, with a gold-value / quantity sorter (asc/desc) -->
            <StackPanel Visibility="{Binding ItemsSorter.HasItems, Converter={StaticResource Bool}}" Margin="0,12,0,0">
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="Items" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"
                               DockPanel.Dock="Left" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ComboBox ItemsSource="{Binding ItemsSorter.SortOptions}"
                                  SelectedIndex="{Binding ItemsSorter.SelectedSortIndex, Mode=TwoWay}"
                                  MinWidth="120" Height="{StaticResource FormControlHeight}" Margin="0,0,6,0" />
                        <ui:Button Command="{Binding ItemsSorter.ToggleDirectionCommand}" Padding="9,0"
                                   Height="{StaticResource FormControlHeight}" ToolTip="{Binding ItemsSorter.DirectionLabel}">
                            <ui:SymbolIcon FontSize="16">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Symbol" Value="ArrowUp24" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ItemsSorter.Descending}" Value="False">
                                                <Setter Property="Symbol" Value="ArrowDown24" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                        </ui:Button>
                    </StackPanel>
                </DockPanel>
                <ItemsControl ItemsSource="{Binding ItemsSorter.View}" ItemTemplate="{StaticResource SessionItemRowTemplate}" />
            </StackPanel>
        </StackPanel>
    </c:PageShell>
</Page>
