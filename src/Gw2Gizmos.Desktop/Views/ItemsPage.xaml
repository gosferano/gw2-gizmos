<Page x:Class="Gw2Gizmos.Desktop.ItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      xmlns:conv="clr-namespace:Gw2Gizmos.Desktop.Converters"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:model="clr-namespace:Gw2Gizmos.RecipeFinder.Model;assembly=Gw2Gizmos.RecipeFinder"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="Items">
    <c:PageShell Title="Items" Scrollable="False">
        <c:PageShell.Resources>
            <conv:CoinConverter x:Key="Coin" />
            <conv:BoolToVisibilityConverter x:Key="Bool" />
            <conv:BoolToVisibilityConverter x:Key="InverseBool" Invert="True" />
            <conv:BoolToFontWeightConverter x:Key="Bold" />

            <!-- One tab header: a rounded-top "browser tab". Selected = brighter (blends into the card body),
                 unselected = dimmer, with a hover step. -->
            <Style x:Key="CardTabItem" TargetType="TabItem">
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="ClipToBounds" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Tab" CornerRadius="4,4,0,0" Padding="16,7" Cursor="Hand"
                                    SnapsToDevicePixels="True" UseLayoutRounding="True"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                <ContentPresenter x:Name="Label" ContentSource="Header" VerticalAlignment="Center"
                                                  TextElement.FontWeight="Medium"
                                                  TextElement.Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Tab" Property="Background"
                                            Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <!-- Same surface as the card body so the selected tab reads as one with it. -->
                                    <Setter TargetName="Tab" Property="Background"
                                            Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                    <Setter TargetName="Label" Property="TextElement.Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Tab strip above; the selected tab's content fills a card directly below it. -->
            <Style x:Key="CardTabControl" TargetType="TabControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" IsItemsHost="True"
                                            HorizontalAlignment="Left" Margin="6,0,0,0" Panel.ZIndex="1" />
                                <!-- Card body; same fill as the selected tab so they read as one surface. No
                                     top border, so the flush selected tab blends in seamlessly (the fill is
                                     semi-transparent, so overlapping would double-darken into a visible line). -->
                                <Border Grid.Row="1" CornerRadius="{DynamicResource ControlCornerRadius}" Padding="14"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,1,1">
                                    <ContentPresenter ContentSource="SelectedContent" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </c:PageShell.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <!-- Sync notice spans the full width, above the search row. -->
                <TextBlock Margin="0,0,0,8" TextWrapping="Wrap" Opacity="0.7"
                           ToolTip="{Binding PricesUpdatedTooltip}">
                    <Run Text="Every tradeable or craftable item; market prices and craft cost where applicable." />
                    <Run Text="{Binding PricesStatus, Mode=OneWay}" />
                </TextBlock>
                <!-- Full-width search box with a refresh button to its right. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" PlaceholderText="search items"
                                Height="{StaticResource FormControlHeight}"
                                Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch"
                               Command="{Binding RefreshCommand}"
                               ToolTip="Reload prices for the current list">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="ArrowSync24" />
                        </ui:Button.Icon>
                    </ui:Button>
                </Grid>
            </StackPanel>

            <ui:Card Grid.Row="1" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <DataGrid ItemsSource="{Binding View}"
                      SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserResizeRows="False" CanUserSortColumns="True" SelectionMode="Single"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent"
                      FontSize="13"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Item" Width="210" SortMemberPath="Name">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <c:ItemImage ItemId="{Binding ItemId}" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Buy" Width="95" SortMemberPath="Buy">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <c:CoinDisplay Copper="{Binding Buy}" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Demand" Width="70"
                                        Binding="{Binding Demand, StringFormat='{}{0:N0}'}" />
                    <DataGridTemplateColumn Header="Sell" Width="95" SortMemberPath="Sell">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <c:CoinDisplay Copper="{Binding Sell}" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Supply" Width="70"
                                        Binding="{Binding Supply, StringFormat='{}{0:N0}'}" />
                    <DataGridTemplateColumn Header="Craft cost" Width="120" SortMemberPath="CraftingCost">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <c:CoinDisplay Copper="{Binding CraftingCost}" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Profit/margin selling instantly into buy orders, and listing at the sell price; both
                         net the 15% trading-post fee. -->
                    <DataGridTemplateColumn Header="Buy profit" Width="120" SortMemberPath="BuyProfit">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <c:CoinDisplay Copper="{Binding BuyProfit}" Signed="True" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Buy margin" Width="80"
                                        Binding="{Binding BuyMargin, StringFormat='{}{0:F0}%'}" />
                    <DataGridTemplateColumn Header="Sell profit" Width="120" SortMemberPath="SellProfit">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <c:CoinDisplay Copper="{Binding SellProfit}" Signed="True" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Sell margin" Width="80"
                                        Binding="{Binding SellMargin, StringFormat='{}{0:F0}%'}" />
                </DataGrid.Columns>
            </DataGrid>
            </ui:Card>

            <GridSplitter Grid.Row="2" Height="8" HorizontalAlignment="Stretch"
                          VerticalAlignment="Center" Background="Transparent" />

            <TabControl Grid.Row="3" VerticalAlignment="Stretch"
                        Style="{StaticResource CardTabControl}" ItemContainerStyle="{StaticResource CardTabItem}">
                    <TabItem Header="History">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="70" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.RowSpan="2" Text="{Binding HistoryPlaceholder}"
                                       Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding History.HasData, Converter={StaticResource InverseBool}}" />

                            <!-- Detail chart: buy/sell lines + volume columns; X range driven by the navigator. -->
                            <lvc:CartesianChart Grid.Row="0" Series="{Binding History.Series}"
                                                XAxes="{Binding History.TimeAxes}" YAxes="{Binding History.ValueAxes}"
                                                TooltipPosition="Top" ZoomMode="None"
                                                FindingStrategy="CompareOnlyXTakeClosest"
                                                Visibility="{Binding History.HasData, Converter={StaticResource Bool}}" />

                            <!-- Navigator: full history with a draggable window that sets the detail range. -->
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding History.NavigatorSeries}"
                                                XAxes="{Binding History.NavigatorTimeAxes}" YAxes="{Binding History.NavigatorValueAxes}"
                                                Sections="{Binding History.Sections}" TooltipPosition="Hidden"
                                                PointerPressedCommand="{Binding History.PointerDownCommand}"
                                                PointerMoveCommand="{Binding History.PointerMoveCommand}"
                                                PointerReleasedCommand="{Binding History.PointerUpCommand}"
                                                Visibility="{Binding History.HasData, Converter={StaticResource Bool}}" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Craft tree">
                        <Grid>
                            <!-- Before the first price poll every cost reads 0, so show a note instead of a
                                 misleading tree of zeros until prices have synced. -->
                            <TextBlock Text="Prices are still syncing — craft costs will appear shortly."
                                       Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding PricesSyncing, Converter={StaticResource Bool}}" />
                            <!-- Empty state: nothing selected, or the selected item has no recipe. -->
                            <TextBlock Text="{Binding CraftTreePlaceholder}"
                                       Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding ShowCraftTreePlaceholder, Converter={StaticResource Bool}}" />
                            <TreeView ItemsSource="{Binding SelectedTree}" Background="Transparent" BorderThickness="0"
                                  Margin="0,8,0,0"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  Visibility="{Binding PricesSyncing, Converter={StaticResource InverseBool}}">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                    <!-- Only the top couple of levels expand by default; deeper nodes (a legendary's
                                         promotion chains run to tens of thousands of nodes) render lazily on expand,
                                         so opening a craft tree doesn't freeze the UI rendering every node at once. -->
                                    <Setter Property="IsExpanded" Value="{Binding AutoExpand, Mode=OneTime}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type model:RecipeNode}"
                                                          ItemsSource="{Binding Ingredients}">
                                    <StackPanel Orientation="Horizontal">
                                        <c:ItemImage ItemId="{Binding ItemId}" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding Count}" FontWeight="Medium" />
                                        <TextBlock Text="x " FontWeight="Medium" />
                                        <TextBlock Text="{Binding ItemName}" FontWeight="Medium" />
                                        <!-- Craft-vs-buy economics: meaningful only with price history on; hidden
                                             (so the tree reads as a plain ingredient breakdown) when it's off. -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding DataContext.PricesEnabled,
                                                                 RelativeSource={RelativeSource AncestorType=Page},
                                                                 Converter={StaticResource Bool}}">
                                            <TextBlock Text="  ·  " Opacity="0.6" />
                                            <TextBlock Text="craft " Opacity="0.6"
                                                       FontWeight="{Binding CraftIsCheaper, Converter={StaticResource Bold}}" />
                                            <!-- Craft cost as coins, or an em-dash when there's no recipe, or the craft
                                                 can't be done because a direct ingredient is an unobtainable dead-end
                                                 (then the node collapses to its buy price). A 0 would read as "free". -->
                                            <c:CoinDisplay Copper="{Binding CraftingCost}" Opacity="0.6"
                                                           FontWeight="{Binding CraftIsCheaper, Converter={StaticResource Bold}}"
                                                           Visibility="{Binding ShowCraftCost, Converter={StaticResource Bool}}" />
                                            <TextBlock Text="—" Opacity="0.6"
                                                       FontWeight="{Binding CraftIsCheaper, Converter={StaticResource Bold}}"
                                                       Visibility="{Binding ShowCraftCost, Converter={StaticResource InverseBool}}" />
                                            <TextBlock Text="  ·  " Opacity="0.6" />
                                            <TextBlock Text="buy " Opacity="0.6"
                                                       FontWeight="{Binding BuyIsCheaper, Converter={StaticResource Bold}}" />
                                            <c:CoinDisplay Copper="{Binding BuyPrice}" Opacity="0.6"
                                                           FontWeight="{Binding BuyIsCheaper, Converter={StaticResource Bold}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                            </TreeView>
                        </Grid>
                    </TabItem>
            </TabControl>
        </Grid>
    </c:PageShell>
</Page>
