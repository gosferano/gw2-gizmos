<Page x:Class="Gw2Gizmos.Desktop.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Title="Dashboard">
    <StackPanel Margin="24">
        <TextBlock Text="Dashboard" FontSize="22" FontWeight="Medium" Margin="0,0,0,16" />
        <WrapPanel>
            <ui:Card Margin="0,0,12,12" Padding="18" Width="170">
                <StackPanel>
                    <TextBlock Text="API key" Opacity="0.7" />
                    <TextBlock Text="{Binding ApiKeyStatus}" FontSize="20" FontWeight="Medium" Margin="0,4,0,0" />
                </StackPanel>
            </ui:Card>
            <ui:Card Margin="0,0,12,12" Padding="18" Width="170">
                <StackPanel>
                    <TextBlock Text="Items synced" Opacity="0.7" />
                    <TextBlock Text="{Binding ItemCount}" FontSize="20" FontWeight="Medium" Margin="0,4,0,0" />
                </StackPanel>
            </ui:Card>
            <ui:Card Margin="0,0,12,12" Padding="18" Width="170">
                <StackPanel>
                    <TextBlock Text="Notifications" Opacity="0.7" />
                    <TextBlock Text="{Binding NotificationCount}" FontSize="20" FontWeight="Medium" Margin="0,4,0,0" />
                </StackPanel>
            </ui:Card>
        </WrapPanel>
    </StackPanel>
</Page>
