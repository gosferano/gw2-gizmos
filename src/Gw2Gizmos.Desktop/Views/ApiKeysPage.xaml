<Page x:Class="Gw2Gizmos.Desktop.ApiKeysPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:c="clr-namespace:Gw2Gizmos.Desktop.Controls"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      Title="API keys">
    <c:PageShell Title="API keys" MaxContentWidth="640">
        <StackPanel>
            <TextBlock Text="GW2 API keys" FontWeight="Medium" />
            <TextBlock Text="Add one key per account. Create one at account.arena.net."
                       Opacity="0.7" Margin="0,2,0,8" TextWrapping="Wrap" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" Text="{Binding ApiKeyInput, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="paste key here" FontFamily="Consolas" />
                <ui:Button Grid.Column="1" Content="Add" Command="{Binding AddCommand}" Appearance="Primary"
                           Margin="8,0,0,0" />
            </Grid>
            <TextBlock Text="{Binding Status}" Opacity="0.8" Margin="0,6,0,0" TextWrapping="Wrap" />

            <ItemsControl ItemsSource="{Binding Keys}" Margin="0,14,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="14,11">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AccountName}" FontWeight="Medium" FontSize="15" />
                                    <TextBlock Text="{Binding KeyName}" Opacity="0.7" Margin="0,1,0,0" />
                                    <!-- Every GW2 permission; granted ones read normally, an enabled feature's
                                         missing permission is red, the rest are dimmed. -->
                                    <ItemsControl ItemsSource="{Binding Permissions}" Margin="0,6,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,6,5" Padding="7,2" CornerRadius="9"
                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                    <TextBlock Text="{Binding Name}" FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Opacity" Value="0.4" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Present}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.9" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding RequiredMissing}" Value="True">
                                                                        <Setter Property="Opacity" Value="1" />
                                                                        <Setter Property="FontWeight" Value="Medium" />
                                                                        <Setter Property="Foreground"
                                                                                Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <!-- Select: makes this the active account (radio-style); accent check when active. -->
                                <Button Grid.Column="1" VerticalAlignment="Center" Padding="8" Margin="10,0,0,0"
                                        Command="{Binding DataContext.SelectAccountCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" ToolTip="Use this account">
                                    <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="18">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Opacity" Value="0.35" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </Button>
                                <!-- Delete button: same compact icon-button styling as the Events reminder/favorite toggles. -->
                                <Button Grid.Column="2" VerticalAlignment="Center" Padding="8" Margin="6,0,0,0"
                                        Command="{Binding DataContext.DeleteCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding AccountId}" ToolTip="Remove this key">
                                    <ui:SymbolIcon Symbol="Delete24" FontSize="18" />
                                </Button>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </c:PageShell>
</Page>
