<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- Override the default net10.0: pin the Windows SDK version so the built-in WinRT projections
         (Windows.UI.Notifications for toasts) are available. -->
    <TargetFramework>net10.0-windows10.0.17763.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <!-- User-facing brand name; project stays Gw2Gizmos.Desktop. -->
    <AssemblyName>Gw2Gizmos</AssemblyName>
    <Version>0.4.4</Version>
    <!-- Use our explicit Program.Main (so VelopackApp.Run() runs before WPF) instead of the WPF SDK's
         auto-generated entry point. -->
    <StartupObject>Gw2Gizmos.Desktop.Program</StartupObject>
    <!-- LiveCharts pulls in OpenTK / SkiaSharp.Views.WPF, which ship only .NETFramework assets; NuGet's
         fallback to them is harmless here (the chart works), so silence the cross-framework restore noise. -->
    <NoWarn>$(NoWarn);NU1701</NoWarn>
    <!-- Embed the brand icon in the exe so the taskbar button uses it. Because the app sets an explicit
         AppUserModelID (for toasts), Windows takes the taskbar icon from the exe/shortcut rather than
         Window.Icon — so the .ico here is what makes the taskbar match the tray + title bar. -->
    <ApplicationIcon>Assets\gw2gizmos.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Serilog" />
    <PackageReference Include="Serilog.Extensions.Hosting" />
    <PackageReference Include="Serilog.Sinks.Console" />
    <PackageReference Include="Serilog.Sinks.File" />
    <PackageReference Include="WPF-UI" />
    <PackageReference Include="WPF-UI.Tray" />
    <PackageReference Include="LiveChartsCore.SkiaSharpView.WPF" />
    <PackageReference Include="Velopack" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Gw2Gizmos.Data.Worker\Gw2Gizmos.Data.Worker.csproj" />
    <!-- Composition root picks the concrete DB provider (the only place SQLite is referenced). -->
    <ProjectReference Include="..\Gw2Gizmos.Data.Provider.Sqlite\Gw2Gizmos.Data.Provider.Sqlite.csproj" />
    <!-- Hardcoded reference data (world-boss / meta / instance schedules) behind the Events timer screen. -->
    <ProjectReference Include="..\Gw2Gizmos.Data.Static\Gw2Gizmos.Data.Static.csproj" />
    <!-- The crafting engine: its tree serializer + RecipeNode model render the profitable-recipe detail. -->
    <ProjectReference Include="..\Gw2Gizmos.RecipeFinder\Gw2Gizmos.RecipeFinder.csproj" />
    <!-- Build the worker CLI alongside, but don't reference its assembly — the app launches it as a
         separate process so its heavy ingestion can't stall the UI thread. -->
    <ProjectReference Include="..\Gw2Gizmos.Data.Worker.Cli\Gw2Gizmos.Data.Worker.Cli.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\gw2gizmos.png" />
  </ItemGroup>

  <!-- Dev (F5/run-from-bin): merge the worker CLI's build output into the app's output dir so the app
       can spawn it as a sibling exe, sharing the runtime + common dependencies (one copy each). Only
       files the app doesn't already emit are copied, so the app always wins on shared assemblies.
       Skipped for RID builds — those go through publish (PublishWorkerCli); running here too would let
       the net10.0\**\* glob recurse into the worker's RID-nested output and re-nest it under win-x64\. -->
  <Target Name="CopyWorkerCli" AfterTargets="Build" Condition="'$(RuntimeIdentifier)' == ''">
    <ItemGroup>
      <!-- Exclude the worker's appsettings*.json: it configures STANDALONE runs only (feature defaults +
           an optional connection string). Bundling it into the app's output is harmful: both the spawned
           worker AND the desktop's own host read appsettings from here, so its relative connection string
           ("Data Source=Data/...") hijacks the absolute DB path they should get from args — sending the
           worker's writes and the desktop's reads to different files. -->
      <_WorkerCliFiles Include="..\Gw2Gizmos.Data.Worker.Cli\bin\$(Configuration)\net10.0\**\*"
                       Exclude="..\Gw2Gizmos.Data.Worker.Cli\bin\$(Configuration)\net10.0\appsettings*.json" />
      <_WorkerCliNew Include="@(_WorkerCliFiles)" Condition="!Exists('$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')" />
      <!-- The worker's loader metadata (deps.json / runtimeconfig.json) AND its own Gw2Gizmos.* assemblies
           must always be refreshed, not just copied when absent: when the worker changes (new code, or a new
           dependency that alters its deps.json) the files already exist here, so !Exists would skip them —
           leaving the spawned worker running stale code or unable to bind a new assembly. These are never
           shared framework assemblies, so refreshing them can't clobber the app's runtime; SkipUnchangedFiles
           avoids needless writes. -->
      <_WorkerCliRefresh Include="@(_WorkerCliFiles)"
                         Condition="'%(Extension)' == '.json' or $([System.String]::Copy('%(Filename)').StartsWith('Gw2Gizmos.'))" />
      <!-- Drop any appsettings.json a prior build copied into the app output, so it can't pollute config. -->
      <_StaleWorkerAppsettings Include="$(OutDir)appsettings*.json" />
    </ItemGroup>
    <Delete Files="@(_StaleWorkerAppsettings)" />
    <Copy SourceFiles="@(_WorkerCliNew)" DestinationFiles="@(_WorkerCliNew->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_WorkerCliRefresh)" DestinationFiles="@(_WorkerCliRefresh->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <!-- Publish: stage the worker CLI's publish (matching the app's self-contained / RID settings), then
       merge it into the app's publish root, copying only files the app doesn't already emit. The app
       must win on shared assemblies: its WindowsDesktop runtime is a superset that satisfies the worker
       (net10.0), whereas the worker's variants (e.g. WindowsBase) could break the WPF app. -->
  <Target Name="PublishWorkerCli" AfterTargets="Publish">
    <PropertyGroup>
      <_AppPublishFull Condition="$([System.IO.Path]::IsPathRooted('$(PublishDir)'))">$(PublishDir)</_AppPublishFull>
      <_AppPublishFull Condition="!$([System.IO.Path]::IsPathRooted('$(PublishDir)'))">$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\$(PublishDir)'))\</_AppPublishFull>
      <_WorkerStage>$([System.IO.Path]::GetFullPath('$(IntermediateOutputPath)WorkerPublish'))\</_WorkerStage>
    </PropertyGroup>
    <MSBuild Projects="$(MSBuildThisFileDirectory)..\Gw2Gizmos.Data.Worker.Cli\Gw2Gizmos.Data.Worker.Cli.csproj"
             Targets="Publish"
             Properties="Configuration=$(Configuration);PublishDir=$(_WorkerStage);SelfContained=$(SelfContained);RuntimeIdentifier=$(RuntimeIdentifier)" />
    <ItemGroup>
      <!-- Same exclusion as CopyWorkerCli: the worker's appsettings*.json is standalone-only, never in the app. -->
      <_WorkerPublished Include="$(_WorkerStage)**\*" Exclude="$(_WorkerStage)appsettings*.json" />
      <_WorkerPublishedNew Include="@(_WorkerPublished)" Condition="!Exists('$(_AppPublishFull)%(RecursiveDir)%(Filename)%(Extension)')" />
    </ItemGroup>
    <Copy SourceFiles="@(_WorkerPublishedNew)" DestinationFiles="@(_WorkerPublishedNew->'$(_AppPublishFull)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
    <!-- The staging publish is a full (self-contained) copy used only to extract the worker's unique
         files + its self-contained host/runtimeconfig; drop it so it doesn't leave ~90 MB of duplicated
         DLLs behind in obj/. -->
    <RemoveDir Directories="$(_WorkerStage)" />
  </Target>

</Project>
